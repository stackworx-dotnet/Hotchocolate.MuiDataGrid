schema {
  query: Query
}

type Query {
  people(filters: MuiDataGridFilterInput, sorting: [MuiDataGridSortItemInput!]): [Person!]!
    @cost(weight: "10")
  mudPeople(filters: MudDataGridFilterInput): [Person!]! @cost(weight: "10")
  input(input: MuiDataGridFilterItemInput!): String
}

type Address {
  id: Int!
  streetNumber: Int!
  province: String!
  streetLine1: String!
  streetLine2: String!
  apartmentId: Int!
  apartment: Apartment!
}

type Apartment {
  id: Int!
  houseNumber: Int!
  name: String!
  price: Decimal!
  sellDate: DateTime
  apartmentType: ApartmentType!
}

type Person {
  id: Int!
  firstname: String!
  lastname: String!
  bio: String
  age: Int!
  married: Boolean!
  gender: Gender!
  weight: Float
  bankAccountBalance: Decimal
  refId: UUID!
  refIdNullable: UUID
  nonGraphQlSerialisedId: UUID!
  dateOfBirth: DateTime!
  marriageDate: DateTime
  idCardReceivedDate: DateTime
  createdAtDate: LocalDate!
  updatedAtDate: LocalDate
  addressId: Int
  address: Address
}

input MudDataGridFilterDefinitionInput {
  field: String!
  operator: String!
  value: MuiValue
  id: Any
}

input MudDataGridFilterInput {
  filterDefinitions: [MudDataGridFilterDefinitionInput!]!
  sortDefinitions: [MudDataGridSortDefinitionInput!]!
}

input MudDataGridSortDefinitionInput {
  field: String!
  descending: Boolean!
}

input MuiDataGridFilterInput {
  items: [MuiDataGridFilterItemInput!]!
  logicOperator: MuiDataGridLinkOperator
  quickFilterValues: MuiValue
  quickFilterLogicOperator: MuiDataGridLinkOperator
}

input MuiDataGridFilterItemInput {
  field: String!
  value: MuiValue
  operator: String!
  id: Any
  fromInput: String
}

input MuiDataGridSortItemInput {
  field: String!
  sort: MuiGridSortDirection!
}

enum ApartmentType {
  RENTAL_PROPERTY
  OWNED_PROPERTY
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MuiDataGridLinkOperator {
  or
  and
}

enum MuiGridSortDirection {
  asc
  desc
}

"The `Any` scalar type represents any valid GraphQL value."
scalar Any @specifiedBy(url: "https://scalars.graphql.org/chillicream/any.html")

"The `DateTime` scalar type represents a date and time with time zone offset information."
scalar DateTime
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/date-time.html")

"The `Decimal` scalar type represents a decimal floating-point number with high precision."
scalar Decimal
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/decimal.html")

"The `LocalDate` scalar type represents a date without time or time zone information."
scalar LocalDate
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/local-date.html")

scalar MuiValue

"The `UUID` scalar type represents a Universally Unique Identifier (UUID) as defined by RFC 9562."
scalar UUID
  @specifiedBy(url: "https://scalars.graphql.org/chillicream/uuid.html")

"The purpose of the `cost` directive is to define a `weight` for GraphQL types, fields, and arguments. Static analysis can use these weights when calculating the overall cost of a query or response."
directive @cost(
  "The `weight` argument defines what value to add to the overall cost for every appearance, or possible appearance, of a type, field, argument, etc."
  weight: String!
) on
  | SCALAR
  | OBJECT
  | FIELD_DEFINITION
  | ARGUMENT_DEFINITION
  | ENUM
  | INPUT_FIELD_DEFINITION
