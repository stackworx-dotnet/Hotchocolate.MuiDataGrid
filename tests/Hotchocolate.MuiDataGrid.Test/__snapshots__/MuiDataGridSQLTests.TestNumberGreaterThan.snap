SELECT "p"."Id", "p"."AddressId", "p"."Age", "p"."Bio", "p"."CreatedAtDate", "p"."DateOfBirth", "p"."Firstname", "p"."Gender", "p"."IdCardReceivedDate", "p"."Lastname", "p"."MarriageDate", "p"."Married", "p"."NonGraphQlSerialisedId", "p"."RefId", "p"."UpdatedAtDate", "p"."Weight"
FROM "People" AS "p"
WHERE "p"."Age" > 5
